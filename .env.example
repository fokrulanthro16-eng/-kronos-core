# ─────────────────────────────────────────────────────────────────────────────
# KRONOS CORE — Backend Environment Variables
# Copy to .env and fill in values before running.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=KRONOS CORE
APP_VERSION=1.0.0
APP_ENV=development

# Secret key for internal signing (min 32 random chars).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-min-32-random-chars

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000

# ─────────────────────────────────────────────────────────────────────────────
# SaaS — Supabase (all optional — leave blank for local demo mode)
# See docs/SUPABASE_AUTH_SETUP.md for how to obtain these values.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL  (Settings → API → Project URL)
SUPABASE_URL=

# Supabase anon/public key  (Settings → API → Project API keys → anon public)
SUPABASE_ANON_KEY=

# Supabase service role key — NEVER expose to frontend
# (Settings → API → Project API keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret used to verify Supabase-issued tokens server-side
# (Settings → API → JWT Settings → JWT Secret)
JWT_SECRET=
