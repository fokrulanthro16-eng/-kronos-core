# ─────────────────────────────────────────────────────────────────────────────
# KRONOS CORE — Frontend Environment Variables
# Copy to .env.local for local development.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
# Local dev:      http://127.0.0.1:8000
# Production:     https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (optional — leave blank for demo mode)
# NEXT_PUBLIC_ prefix = safe for browser bundle
# NEVER put SUPABASE_SERVICE_ROLE_KEY here — it must stay backend-only
# See docs/SUPABASE_AUTH_SETUP.md for setup instructions.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL  (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key  (Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Stripe (optional — leave blank for demo mode)
# NEXT_PUBLIC_ prefix = safe for browser bundle
# NEVER put STRIPE_SECRET_KEY here — backend-only
# ─────────────────────────────────────────────────────────────────────────────

# Stripe publishable key  (Dashboard → Developers → API keys → Publishable key)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
